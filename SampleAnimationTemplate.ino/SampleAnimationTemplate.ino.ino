// Calculate number of frames automatically
#define FRAME_COUNT (sizeof(frames) / sizeof(frames[0]))

void setup() {
  Serial.begin(115200);

  // Configure Pico I2C1
  Wire1.setSDA(PICO_SDA);
  Wire1.setSCL(PICO_SCL);
  Wire1.begin();

  if (!display.begin(i2c_Address, true)) {
    Serial.println("SH1106 not found");
    for (;;);
  }

  display.clearDisplay();
  display.display();
}

int currentFrame = 0;

void loop() {
  display.clearDisplay();
  
  // (48, 16) centers a 32x32 image on the 128x64 screen
  // Change these coordinates if your FRAME_WIDTH/HEIGHT are different
  display.drawBitmap(48, 16, frames[currentFrame], FRAME_WIDTH, FRAME_HEIGHT, SH110X_WHITE);
  
  display.display();

  currentFrame = (currentFrame + 1) % FRAME_COUNT;
  delay(FRAME_DELAY);
}